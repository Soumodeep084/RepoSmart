# Server
PORT=5000
# NODE_ENV=development

# Database
MONGO_URI=

# Auth
JWT_SECRET=

# GitHub API (required)
GITHUB_API_BASE=https://api.github.com
GITHUB_API_VERSION=2022-11-28
# Optional: add a GitHub token to increase rate limits
GITHUB_TOKEN=

# Google OAuth (required by the frontend; the client id is NOT a secret)
GOOGLE_CLIENT_ID=

# AI (OpenRouter)
# IMPORTANT: This project is configured to use ONLY free usage.
OPENROUTER_API_KEY=
# Default: OpenRouter's free route (the server also enforces $0 routing via provider.max_price)
OPENROUTER_MODEL=openrouter/free
# Optional: ordered fallbacks (models must end with ':free', except openrouter/* routes)
# OPENROUTER_MODELS=openrouter/free,google/gemma-3-27b-it:free

# Email (password reset / OTP)
# Default implementation uses Mailtrap SMTP.
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=

# Alternative: Gmail SMTP (requires code change in server/config/sendMail.js)
# EMAIL_USER=
# EMAIL_PASS=

# Optional: Redis cache for /api/repo/analyze
# If REDIS_URI is not set, caching is disabled.
REDIS_URI=
# Default: 3600 (1 hour)
REDIS_ANALYZE_TTL_SECONDS=3600